DATABASE_URL="SUA_URL_AQUI" ## algo como postgresql://postgres:senha@host:porta/banco
BCRYPT_SALT=12
JWT_SECRET_KEY="SUA_CHAVE_SECRETA_AQUI" ## uma secret key para utilizar
